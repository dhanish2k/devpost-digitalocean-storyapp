# DigitalOcean Gradient AI — model access key (required for story generation)
MODEL_ACCESS_KEY=your_do_gradient_key_here

# Model for seed generation (fast, used for 3 brief synopses)
MODEL_NAME=llama3.3-70b-instruct

# Model for full story generation — set to a stronger model if available.
# Check https://cloud.digitalocean.com/gen-ai for the current model catalog.
# Candidates: llama3.1-405b-instruct, mistral-large-latest, etc.
STORY_MODEL_NAME=llama3.3-70b-instruct
