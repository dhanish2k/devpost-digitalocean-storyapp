# DigitalOcean Gradient AI — model access key (required for story generation)
MODEL_ACCESS_KEY=your_do_gradient_key_here

# Fallback model if the agent-specific vars below are not set
MODEL_NAME=llama3.3-70b-instruct

# Model for seed generation (3 brief synopses — fast/cheap is fine)
SEED_MODEL_NAME=llama3.3-70b-instruct

# Model for full story generation (use a stronger model for better quality)
# Check https://cloud.digitalocean.com/gen-ai for available models
# NOTE: deepseek-r1-distill-llama-70b does NOT support tool calling (structured output) — use llama3.3-70b-instruct
STORY_MODEL_NAME=llama3.3-70b-instruct

# Environment name — used to tag traces in Logfire ("development" or "production")
ENVIRONMENT=development

# Logfire observability token — get from https://logfire.pydantic.dev
# If not set, logfire runs locally only (no traces sent to cloud)
LOGFIRE_TOKEN=
